{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push:*)",
      "Bash(awk \"/'core-java':/,/'spring-framework':/\" /Users/sathishkumarramalingam/projects/JavaIQ/src/app/features/tutorials/tutorial-detail.component.ts)",
      "Bash(awk \"/'spring-boot':/,/'hibernate':/\" /Users/sathishkumarramalingam/projects/JavaIQ/src/app/features/tutorials/tutorial-detail.component.ts)",
      "Bash(ls /Users/sathishkumarramalingam/projects/JavaIQ/src/app/features/tutorials/topics/dp-*.component.ts)",
      "Bash(xargs -I{} basename {} .component.ts)",
      "Skill(update-config)",
      "Bash(git commit -m ' *)",
      "Bash(git checkout *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | xargs -I {} npx prettier --write {} 2>/dev/null || true",
            "statusMessage": "Formatting with Prettier..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | grep -qE '[.](ts|js)$' && cd /Users/sathishkumarramalingam/projects/JavaIQ && npm test -- --run 2>/dev/null || true",
            "statusMessage": "Running tests...",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '(now | todate) + \" \" + .tool_input.command' >> ~/.claude/bash-log.txt 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Done\" with title \"Claude Code\"' 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
